# Backend Production Dockerfile
# Optimized Python runtime for Gateway API and LangGraph Server
#
# Build: docker build -f backend/Dockerfile.prod -t deer-flow-backend .
# Run (Gateway): docker run -p 8001:8001 deer-flow-backend uvicorn src.gateway.app:app --host 0.0.0.0 --port 8001
# Run (LangGraph): docker run -p 2024:2024 deer-flow-backend langgraph up --host 0.0.0.0 --port 2024

# ============================================
# Base Stage - Common runtime dependencies
# ============================================
FROM python:3.12-slim AS base

# Install only runtime-required system packages (no build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    poppler-utils \
    qpdf \
    imagemagick \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Install uv package manager (fast Python package installer)
COPY --from=ghcr.io/astral-sh/uv:0.7.20 /uv /uvx /usr/local/bin/

WORKDIR /app

# ============================================
# Builder Stage - Install Python dependencies
# ============================================
FROM base AS builder

# Copy backend project files needed to install the project itself.
# `uv sync` installs the local package, so packaging metadata and source must
# exist in the build context instead of only the lockfile.
COPY backend ./backend/

# Install production dependencies only (no dev dependencies)
# Uses cache mount for faster rebuilds
RUN --mount=type=cache,target=/root/.cache/uv \
    cd backend && uv sync --frozen --no-dev

# ============================================
# Runner Stage - Production runtime
# ============================================
FROM base AS runner

# Build argument: whether to include Docker CLI (for DooD sandbox mode)
ARG INCLUDE_DOCKER_CLI=false

# Copy Docker CLI from docker:cli image (will be removed if not needed)
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker-optional

# Conditionally keep or remove Docker CLI based on INCLUDE_DOCKER_CLI arg
RUN if [ "$INCLUDE_DOCKER_CLI" = "true" ]; then \
    mv /usr/local/bin/docker-optional /usr/local/bin/docker && \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*; \
    else \
    rm -f /usr/local/bin/docker-optional; \
    fi

# Copy virtual environment from builder
COPY --from=builder /app/backend/.venv /app/backend/.venv

# Copy application source code
COPY backend/src ./backend/src
COPY backend/langgraph.json ./backend/
COPY backend/pyproject.toml ./backend/
COPY backend/README.md ./backend/

# Create data directory for persistent storage
RUN mkdir -p /app/backend/.deer-flow

# Expose ports (gateway: 8001, langgraph: 2024)
EXPOSE 8001 2024

# Default command (can be overridden in docker-compose)
WORKDIR /app/backend
CMD [".venv/bin/uvicorn", "src.gateway.app:app", "--host", "0.0.0.0", "--port", "8001"]
