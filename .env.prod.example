# DeerFlow Production Environment Variables
# Copy this file to .env.prod and fill in your values
#
# Usage: docker compose -f docker/docker-compose-prod.yaml --env-file .env.prod up -d

# ==========================================
# REQUIRED: LLM API Keys
# ==========================================

# Anthropic Claude (recommended for production)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ==========================================
# OPTIONAL: Frontend Authentication
# ==========================================

# Session signing secret for frontend auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Admin login credentials (defaults: admin@admin.com / admin)
# ADMIN_EMAIL=admin@admin.com
# ADMIN_PASSWORD=admin

# ==========================================
# OPTIONAL: Tool API Keys

# OpenAI GPT models
# OPENAI_API_KEY=your-openai-api-key

# Google Gemini models
# GOOGLE_API_KEY=your-google-api-key

# DeepSeek models
# DEEPSEEK_API_KEY=your-deepseek-api-key

# Volcengine (Doubao) models
# VOLCENGINE_API_KEY=your-volcengine-api-key

# Kimi/Moonshot models
# MOONSHOT_API_KEY=your-moonshot-api-key

# Novita AI (OpenAI-compatible)
# NOVITA_API_KEY=your-novita-api-key

# ==========================================
# OPTIONAL: Tool API Keys
# ==========================================

# Tavily web search (recommended for web search capability)
TAVILY_API_KEY=your-tavily-api-key

# InfoQuest web search/fetch
# INFOQUEST_API_KEY=your-infoquest-api-key

# ==========================================
# OPTIONAL: IM Channel Configuration
# ==========================================

# Feishu/Lark integration
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# Telegram bot integration
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_ALLOWED_USERS=123456789,987654321  # Empty = allow all

# ==========================================
# OPTIONAL: Docker/Sandbox Configuration
# ==========================================

# Include Docker CLI in backend (for DooD sandbox mode)
# WARNING: Enabling this mounts the Docker socket which has security implications
INCLUDE_DOCKER_CLI=false

# Docker socket path (only needed if INCLUDE_DOCKER_CLI=true)
DOCKER_SOCKET=/var/run/docker.sock

# ==========================================
# OPTIONAL: Deployment Configuration
# ==========================================

# Image version tag
VERSION=latest

# Nginx exposed port (change if you want different port)
NGINX_PORT=2026

# Internal service URLs used by channel integrations inside Docker
LANGGRAPH_INTERNAL_URL=http://langgraph:2024
GATEWAY_INTERNAL_URL=http://gateway:8001
